<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:orientation="vertical"
        android:background="@drawable/gradient_bg"
        android:padding="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏆 Kreeda-Prerana"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:elevation="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Scout Rural Sports Talent"
            android:textColor="#E0F2F1"
            android:textSize="18sp"
            android:letterSpacing="0.02"/>

    </LinearLayout>

    <!-- Buttons Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:orientation="vertical"
        android:padding="20dp">

        <Button
            android:id="@+id/btnAddAthlete"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="👤 Add Athlete"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="@drawable/button_card"
            android:textColor="#000000"
            android:elevation="6dp"
            android:layout_marginBottom="14dp"/>

        <Button
            android:id="@+id/btnBatch"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="👥 Batch Entry"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="@drawable/button_card"
            android:textColor="#000000"
            android:elevation="6dp"
            android:layout_marginBottom="14dp"/>

        <Button
            android:id="@+id/btnTrial"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="⏱ Trial Logger"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="@drawable/button_card"
            android:textColor="#000000"
            android:elevation="6dp"
            android:layout_marginBottom="14dp"/>

        <Button
            android:id="@+id/btnLeader"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="🏅 Leaderboard"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="@drawable/button_card"
            android:textColor="#000000"
            android:elevation="6dp"
            android:layout_marginBottom="14dp"/>

        <Button
            android:id="@+id/btnGraph"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="📈 Talent Curve"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="@drawable/button_card"
            android:textColor="#000000"
            android:elevation="6dp"
            android:layout_marginBottom="14dp"/>

        <Button
            android:id="@+id/btnGenAI"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="🤖 Gen AI"
            android:textSize="20sp"
            android:textStyle="bold"
            android:background="@drawable/button_card"
            android:textColor="#000000"
            android:elevation="6dp"
            android:layout_marginBottom="14dp"/>

    </LinearLayout>

</RelativeLayout>